      "tolerance": 0.0
    },
    {
      "sensorIds": ["C", "D", "E"],
      "desiredDutyCycle": 15.0,
      "tolerance": 0.0
    }
  ],
  "adjacency": {
    "A": ["B", "C"],
    "B": ["A", "C", "E"],
    "C": ["A", "B", "D"],
    "D": ["C", "E"],
    "E": ["B", "D"]
  }
}

